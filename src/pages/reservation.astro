---
import Layout from '../layouts/Layout.astro';
import reservationConfig from '../config/reservation.json';
const reservationsOpen = reservationConfig.open;
---

<Layout
  title="Réserver une Table — La Table de la Dyle, Wavre"
  description="Réservez votre table à La Table de la Dyle, brasserie belge à Wavre. Réservation en ligne rapide et gratuite. Terrasse disponible selon disponibilités."
>

  <section class="resa-hero">
    <div class="resa-hero__content">
      <p class="section__label">Bienvenue chez nous</p>
      <h1>Réserver une table</h1>
      <p class="resa-hero__intro">
        {reservationsOpen
          ? "Réservez votre table à La Table de la Dyle en quelques secondes via notre système de réservation en ligne. Nous avons hâte de vous accueillir !"
          : "Les réservations en ligne sont momentanément indisponibles. N'hésitez pas à nous contacter directement."}
      </p>
    </div>
  </section>

  {reservationsOpen ? (
    <section class="section resa-widget">
      <div class="container">
<div class="resa-widget__cta">
          <a
            href="https://octotable.com/book/restaurant/1001980/booking/new"
            target="_blank"
            rel="noopener noreferrer"
            class="btn btn--primary"
          >
            Réserver une table en ligne
          </a>
        </div>
      </div>
    </section>
  ) : (
    <section class="section resa-closed">
      <div class="container text-center">
        <div class="resa-closed__icon" aria-hidden="true">✦</div>
        <h2 class="resa-closed__heading">Réservations momentanément indisponibles</h2>
        <p class="resa-closed__text">
          Les réservations en ligne ne sont pas disponibles pour le moment.<br />
          Revenez nous voir prochainement ou contactez-nous directement.
        </p>
        <div class="resa-closed__divider"></div>
        <p class="resa-closed__contact">
          Pour réserver, contactez-nous directement&nbsp;:
        </p>
        <div class="contact-links">
          <a href="tel:+32476820747" class="btn btn--outline-dark">
            +32 476 82 07 47
          </a>
          <a href="mailto:latabledeladyle@gmail.com" class="btn btn--outline-dark">
            latabledeladyle@gmail.com
          </a>
        </div>
      </div>
    </section>
  )}

  <section class="section section--grey">
    <div class="container">
      <div class="info-grid">

        <div class="info-card">
          <h3>Informations pratiques</h3>
          <ul class="info-list">
            <li>Les réservations sont acceptées jusqu'à 20 minutes avant le service.</li>
            <li>Pour les groupes de plus de 10 personnes, veuillez nous contacter par téléphone ou par e-mail.</li>
            <li>En cas d'annulation, merci de nous appeler directement.</li>
            <li>Nous faisons de notre mieux pour honorer les demandes de terrasse selon la météo et les disponibilités.</li>
          </ul>
        </div>

        <div class="info-card">
          <h3>Nos horaires</h3>
          <dl class="hours-list">
            <div>
              <dt>Lundi</dt>
              <dd>Fermé</dd>
            </div>
            <div>
              <dt>Mardi</dt>
              <dd>18h00 – 22h00</dd>
            </div>
            <div>
              <dt>Mercredi</dt>
              <dd>11h00 – 22h00</dd>
            </div>
            <div>
              <dt>Jeudi</dt>
              <dd>11h00 – 22h00</dd>
            </div>
            <div>
              <dt>Vendredi</dt>
              <dd>11h00 – 22h00</dd>
            </div>
            <div>
              <dt>Samedi</dt>
              <dd>11h00 – 22h00</dd>
            </div>
            <div>
              <dt>Dimanche</dt>
              <dd>11h00 – 22h00</dd>
            </div>
          </dl>
        </div>

      </div>
    </div>
  </section>

  {reservationsOpen && (
    <section class="section text-center">
      <div class="container">
        <h2>Vous préférez nous appeler&nbsp;?</h2>
        <p class="section__intro">
          Notre équipe est disponible pendant les heures d'ouverture
          pour répondre à toutes vos questions.
        </p>
        <div class="contact-links">
          <a href="tel:+32476820747" class="btn btn--outline-dark">
            +32 476 82 07 47
          </a>
          <a href="mailto:latabledeladyle@gmail.com" class="btn btn--outline-dark">
            latabledeladyle@gmail.com
          </a>
        </div>
      </div>
    </section>
  )}

</Layout>

<style>
  /* ---- Hero ---- */
  .resa-hero {
    position: relative;
    min-height: 420px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-black) url('/images/puis_lumineux.jpg') center/cover no-repeat;
    text-align: center;
    overflow: hidden;
  }

  .resa-hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.55);
  }

  .resa-hero__content {
    position: relative;
    z-index: 1;
    padding: var(--space-xl) var(--space-md);
    max-width: 640px;
    width: 100%;
  }

  .resa-hero__content .section__label {
    color: rgba(255, 255, 255, 0.6);
  }

  .resa-hero__content h1 {
    color: var(--color-white);
    margin-bottom: var(--space-sm);
  }

  .resa-hero__intro {
    color: rgba(255, 255, 255, 0.75);
    font-size: 1.05rem;
    line-height: 1.7;
    max-width: 520px;
    margin: 0 auto;
  }

  @media (max-width: 768px) {
    .resa-hero {
      min-height: 280px;
    }
  }

  .resa-widget {
    padding: var(--space-xl) 0;
  }

  .resa-widget__cta {
    text-align: center;
    margin-top: var(--space-md);
  }

  .info-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: var(--space-md);
  }

  .info-card {
    background: var(--color-white);
    padding: var(--space-md);
    border-left: 3px solid var(--color-black);
  }

  .info-card h3 {
    margin-bottom: var(--space-sm);
  }

  .info-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
  }

  .info-list li {
    padding-left: 1.2em;
    position: relative;
    color: var(--color-grey-text);
    font-size: 0.95rem;
    max-width: 100%;
  }

  .info-list li::before {
    content: '–';
    position: absolute;
    left: 0;
    color: var(--color-grey-text);
  }

  .hours-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
  }

  .hours-list div {
    display: flex;
    justify-content: space-between;
    gap: var(--space-sm);
    padding-bottom: var(--space-xs);
    border-bottom: 1px solid var(--color-grey-mid);
    font-size: 0.9rem;
  }

  .hours-list dt {
    color: var(--color-black);
    font-weight: 600;
  }

  .hours-list dd {
    color: var(--color-grey-text);
    text-align: right;
  }

  .contact-links {
    display: flex;
    gap: var(--space-sm);
    justify-content: center;
    flex-wrap: wrap;
    margin-top: var(--space-sm);
  }

  /* ---- Closed state ---- */
  .resa-closed {
    padding: var(--space-xl) 0;
  }

  .resa-closed__icon {
    font-size: 1.5rem;
    color: var(--color-grey-text);
    opacity: 0.4;
    margin-bottom: var(--space-sm);
  }

  .resa-closed__heading {
    font-family: var(--font-heading);
    font-size: clamp(1.6rem, 4vw, 2.4rem);
    color: var(--color-black);
    margin-bottom: var(--space-sm);
  }

  .resa-closed__text {
    font-size: 1.05rem;
    color: var(--color-grey-text);
    line-height: 1.8;
    margin-bottom: var(--space-md);
  }

  .resa-closed__divider {
    width: 3rem;
    height: 1px;
    background: var(--color-grey-mid);
    margin: var(--space-md) auto;
  }

  .resa-closed__contact {
    font-size: 0.9rem;
    color: var(--color-grey-text);
    margin-bottom: var(--space-sm);
  }
</style>
