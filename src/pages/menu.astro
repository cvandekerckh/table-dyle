---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Notre Menu — La Table de la Dyle, Brasserie Belge Wavre"
  description="Consultez la carte de La Table de la Dyle : cuisine belge de saison, produits frais et locaux."
>

  <section class="menu-hero">
    <div class="menu-hero__content">
      <p class="section__label">À la carte</p>
      <h1>Notre Menu</h1>
      <p class="menu-hero__intro">
        Découvrez notre carte, composée de produits frais et de saison.
        Notre menu évolue régulièrement pour refléter le meilleur du moment
        et les saveurs du terroir belge.
      </p>
    </div>
  </section>

  <section class="section section--grey menu-carte">
    <div class="menu-carte__header">
      <div class="ornament">✦</div>
      <p class="menu-carte__label"><em>Notre carte du moment</em></p>
    </div>
    <img
      src="/images/menu.png"
      alt="Carte de La Table de la Dyle"
      class="carte-img"
      loading="eager"
    />
  </section>

  <section class="section section--dark text-center">
    <div class="container">
      <h2>Une question sur notre carte&nbsp;?</h2>
      <p class="section__intro">
        N'hésitez pas à nous contacter ou à réserver pour en savoir plus
        sur nos suggestions du moment.
      </p>
      <div class="menu-cta-group">
        <a href="/reservation" class="btn btn--outline">Réserver une table</a>
        <a href="/contact" class="btn btn--outline">Nous contacter</a>
      </div>
    </div>
  </section>

</Layout>

<style>
  .menu-hero {
    min-height: 55vh;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-black) url('/images/ambiance.jpg') center/cover no-repeat;
    position: relative;
    text-align: center;
    padding: var(--space-md);
  }

  .menu-hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.58);
  }

  .menu-hero__content {
    position: relative;
    z-index: 1;
    color: var(--color-white);
    max-width: 700px;
  }

  .menu-hero__content .section__label {
    opacity: 0.6;
  }

  .menu-hero__content h1 {
    color: var(--color-white);
    margin: var(--space-xs) 0 var(--space-sm);
  }

  .menu-hero__intro {
    color: rgba(255, 255, 255, 0.75);
    font-size: 1rem;
    line-height: 1.7;
    max-width: 560px;
    margin: 0 auto;
  }

  .menu-carte {
    padding-top: var(--space-md);
    padding-bottom: var(--space-lg);
  }

  .menu-carte__header {
    text-align: center;
    margin-bottom: var(--space-md);
  }

  .ornament {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin: 0 auto var(--space-sm);
    max-width: 200px;
    font-family: var(--font-heading);
    color: var(--color-grey-text);
    font-size: 0.8rem;
  }

  .ornament::before,
  .ornament::after {
    content: '';
    flex: 1;
    height: 1px;
    background: var(--color-grey-mid);
  }

  .menu-carte__label {
    font-family: var(--font-heading);
    font-size: 1.5rem;
    color: var(--color-black);
    text-align: center;
  }

  .carte-img {
    display: block;
    width: 100%;
    max-width: 1100px;
    margin: 0 auto;
    box-shadow: 0 4px 32px rgba(0,0,0,0.10);
  }

  .menu-cta-group {
    display: flex;
    gap: var(--space-sm);
    justify-content: center;
    flex-wrap: wrap;
    margin-top: var(--space-sm);
  }
</style>
