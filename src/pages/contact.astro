---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Contact & Accès — La Table de la Dyle, Wavre"
  description="Adresse, téléphone et accès à La Table de la Dyle, 27 rue Charles Sambon, 1300 Wavre. Plan Google Maps disponible."
>

  <!-- ========================================================
       SPLIT HERO: image + info
       ======================================================== -->
  <section class="contact-split">

    <div class="contact-split__image" role="img" aria-label="La Table de la Dyle"></div>

    <div class="contact-split__info">
      <div class="contact-split__inner">
        <p class="section__label">Nous trouver</p>
        <h1>Contact &amp; Accès</h1>
        <div class="ornament">✦</div>

        <div class="contact-blocks">

          <div class="contact-block">
            <p class="contact-block__label">Adresse</p>
            <address>
              27 rue Charles Sambon<br />
              1300 Wavre, Belgique
            </address>
          </div>

          <div class="contact-block">
            <p class="contact-block__label">Téléphone</p>
            <a href="tel:+32476820747">+32 476 82 07 47</a>
          </div>

          <div class="contact-block">
            <p class="contact-block__label">Email</p>
            <a href="mailto:latabledeladyle@gmail.com">latabledeladyle@gmail.com</a>
          </div>

          <div class="contact-block">
            <p class="contact-block__label">Horaires</p>
            <p>
              Lundi : Fermé<br />
              Mardi : 18h–22h<br />
              Mer – Dim : 11h–22h
            </p>
          </div>

        </div>

        <a href="/reservation" class="btn btn--outline">Réserver une table</a>
      </div>
    </div>

  </section>

  <!-- ========================================================
       FULL-WIDTH MAP
       ======================================================== -->
  <div class="contact-map">
    <iframe
      src="https://maps.google.com/maps?q=27+rue+Charles+Sambon,+1300+Wavre,+Belgique&output=embed"
      width="100%"
      height="480"
      style="border: 0;"
      allowfullscreen
      loading="lazy"
      referrerpolicy="no-referrer-when-downgrade"
      title="Localisation de La Table de la Dyle"
      aria-label="Carte Google Maps — La Table de la Dyle, 27 rue Charles Sambon, Wavre"
    ></iframe>
  </div>

</Layout>

<style>
  /* ---- Split layout ---- */
  .contact-split {
    display: grid;
    grid-template-columns: 1fr 1fr;
    min-height: calc(100vh - 60px);
  }

  .contact-split__image {
    background: url('/images/contact.jpg') center/cover no-repeat;
    min-height: 400px;
  }

  .contact-split__info {
    background: var(--color-black);
    color: var(--color-white);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: var(--space-xl) var(--space-lg);
  }

  .contact-split__inner {
    max-width: 420px;
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .contact-split__inner .section__label {
    opacity: 0.5;
  }

  .contact-split__inner h1 {
    color: var(--color-white);
    margin: 0;
  }

  /* ornament on dark bg */
  .ornament {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    max-width: 180px;
    font-family: var(--font-heading);
    color: rgba(255, 255, 255, 0.3);
    font-size: 0.8rem;
  }

  .ornament::before,
  .ornament::after {
    content: '';
    flex: 1;
    height: 1px;
    background: rgba(255, 255, 255, 0.2);
  }

  /* Contact blocks */
  .contact-blocks {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    padding-top: var(--space-md);
  }

  .contact-block {
    display: grid;
    grid-template-columns: 100px 1fr;
    gap: var(--space-sm);
    align-items: start;
    padding-bottom: var(--space-sm);
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
  }

  .contact-block:last-child {
    border-bottom: none;
  }

  .contact-block__label {
    font-family: var(--font-heading);
    font-size: 0.8rem;
    font-style: italic;
    color: rgba(255, 255, 255, 0.45);
    padding-top: 0.15rem;
    max-width: 100%;
  }

  .contact-block address,
  .contact-block p,
  .contact-block a {
    font-style: normal;
    color: var(--color-white);
    line-height: 1.7;
    max-width: 100%;
  }

  .contact-block a:hover {
    opacity: 0.7;
  }

  /* Map */
  .contact-map iframe {
    display: block;
    width: 100%;
    height: 480px;
  }

  /* Mobile */
  @media (max-width: 768px) {
    .contact-split {
      grid-template-columns: 1fr;
      min-height: auto;
    }

    .contact-split__image {
      min-height: 300px;
    }

    .contact-split__info {
      padding: var(--space-lg) var(--space-md);
    }

    .contact-block {
      grid-template-columns: 90px 1fr;
    }
  }
</style>
