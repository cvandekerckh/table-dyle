---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Contact & Accès — La Table de la Dyle, Wavre"
  description="Adresse, téléphone et accès à La Table de la Dyle, 27 rue Charles Sambon, 1300 Wavre. Plan Google Maps disponible."
>

  <section class="section contact-hero">
    <div class="container">
      <p class="section__label">Nous trouver</p>
      <h1>Contact &amp; Accès</h1>
    </div>
  </section>

  <section class="section contact-section">
    <div class="container">
      <div class="contact-grid">

        <!-- Info -->
        <div class="contact-info">
          <div class="contact-block">
            <div class="contact-icon" aria-hidden="true"></div>
            <div>
              <p class="contact-block__label">Adresse</p>
              <address>
                27 rue Charles Sambon<br />
                1300 Wavre, Belgique
              </address>
            </div>
          </div>

          <div class="contact-block">
            <div class="contact-icon" aria-hidden="true"></div>
            <div>
              <p class="contact-block__label">Téléphone</p>
              <a href="tel:+32476820747">+32 476 82 07 47</a>
            </div>
          </div>

          <div class="contact-block">
            <div class="contact-icon" aria-hidden="true"></div>
            <div>
              <p class="contact-block__label">Email</p>
              <a href="mailto:latabledeladyle@gmail.com">latabledeladyle@gmail.com</a>
            </div>
          </div>

          <div class="contact-block">
            <div class="contact-icon" aria-hidden="true"></div>
            <div>
              <p class="contact-block__label">Horaires</p>
              <p>
                Lundi : Fermé<br />
                Mardi : 18h–22h<br />
                Mer – Dim : 11h–22h
              </p>
            </div>
          </div>

          <a href="/reservation" class="btn btn--primary">
            Réserver une table
          </a>
        </div>

        <!-- Map -->
        <div class="contact-map">
          <iframe
            src="https://maps.google.com/maps?q=27+rue+Charles+Sambon,+1300+Wavre,+Belgique&output=embed"
            width="100%"
            height="480"
            style="border: 0;"
            allowfullscreen
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            title="Localisation de La Table de la Dyle"
            aria-label="Carte Google Maps — La Table de la Dyle, 27 rue Charles Sambon, Wavre"
          ></iframe>
        </div>

      </div>
    </div>
  </section>

</Layout>

<style>
  .contact-hero {
    padding-top: var(--space-xl);
    padding-bottom: var(--space-sm);
  }

  .contact-hero h1 {
    margin-top: var(--space-xs);
  }

  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 1.4fr;
    gap: var(--space-lg);
    align-items: start;
  }

  @media (max-width: 768px) {
    .contact-grid {
      grid-template-columns: 1fr;
    }
  }

  .contact-info {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .contact-block {
    display: flex;
    gap: var(--space-sm);
    align-items: flex-start;
  }

  .contact-icon {
    width: 0.5rem;
    height: 0.5rem;
    background: var(--color-black);
    border-radius: 50%;
    flex-shrink: 0;
    margin-top: 0.6rem;
  }

  .contact-block__label {
    font-family: var(--font-heading);
    font-size: 0.9rem;
    font-style: italic;
    color: var(--color-grey-text);
    margin-bottom: 0.25rem;
    max-width: 100%;
  }

  .contact-block address,
  .contact-block p,
  .contact-block a {
    font-style: normal;
    color: var(--color-black);
    line-height: 1.7;
    max-width: 100%;
  }

  .contact-block a:hover {
    text-decoration: underline;
  }

  .contact-map {
    border: 1px solid var(--color-grey-mid);
    overflow: hidden;
  }

  .contact-map iframe {
    display: block;
  }
</style>
